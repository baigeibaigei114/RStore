<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.remotesensing.platform.mapper.RsTaskLogMapper">

    <insert id="insert" parameterType="com.remotesensing.platform.entity.RsTaskLog"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO rs_task_log (
            task_id,
            log_level,
            message,
            detail
        ) VALUES (
            #{taskId},
            #{logLevel},
            #{message},
            CAST(NULLIF(#{detail}, '') AS jsonb)
        )
    </insert>
</mapper>
