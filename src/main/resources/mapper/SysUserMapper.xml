<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.remotesensing.platform.mapper.SysUserMapper">

    <select id="selectById" resultType="com.remotesensing.platform.entity.SysUser">
        SELECT
            id,
            username,
            password_hash,
            display_name,
            role,
            status,
            created_at,
            updated_at
        FROM sys_user
        WHERE id = #{id}
    </select>

    <select id="selectByUsername" resultType="com.remotesensing.platform.entity.SysUser">
        SELECT
            id,
            username,
            password_hash,
            display_name,
            role,
            status,
            created_at,
            updated_at
        FROM sys_user
        WHERE username = #{username}
    </select>
</mapper>
